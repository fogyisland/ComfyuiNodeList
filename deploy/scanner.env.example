# Production environment for the Celery worker / beat / trigger-api systemd units.
# systemd loads this via EnvironmentFile= in each unit file.

# --- Database (same MySQL as web) ---
DATABASE_URL=mysql://comfyui:CHANGE_ME@127.0.0.1:3306/comfyui_nodes

# --- Redis (Celery broker) ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# --- GitHub API (5000 req/h vs 60 anonymous) ---
SCANNER_GITHUB_TOKEN=ghp_CHANGE_ME

# --- Trigger API (Plan 5) ---
TRIGGER_API_HOST=127.0.0.1
TRIGGER_API_PORT=8081

# --- Celery worker tuning ---
CELERY_WORKER_CONCURRENCY=4  # 4 parallel worker processes (prefork)
CELERY_LOG_LEVEL=info
