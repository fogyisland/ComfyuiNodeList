# Production environment for the Next.js web app (comfyui-web systemd unit).
# systemd loads this via EnvironmentFile= in the unit file.

# --- Database ---
DATABASE_URL=mysql://comfyui:CHANGE_ME@127.0.0.1:3306/comfyui_nodes

# --- NextAuth (required) ---
NEXTAUTH_SECRET=  # openssl rand -base64 32
NEXTAUTH_URL=https://nodes.example.com  # public URL

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=
GITHUB_SECRET=
BOOTSTRAP_ADMIN_GITHUB_ID=0  # your GitHub numeric ID

# --- Celery trigger API (Plan 5) ---
SCANNER_TRIGGER_API_URL=http://127.0.0.1:8081

# --- Server ---
NODE_ENV=production
PORT=3000
HOST=127.0.0.1  # bind to localhost only; nginx reverse-proxies
