DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/comfyui_nodes"
NEXTAUTH_SECRET="dev-secret-replace-in-production-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GITHUB_CLIENT_ID="your-github-oauth-app-client-id"
GITHUB_SECRET="your-github-oauth-app-client-secret"
BOOTSTRAP_ADMIN_GITHUB_ID="0"

# --- Scanner (Plan 4) ---
# Personal Access Token for GitHub API (5000 req/h vs 60 anonymous).
# Generate at https://github.com/settings/tokens (no scopes required for public repos).
SCANNER_GITHUB_TOKEN=
# Redis broker used by Celery for the Python scanner.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Trigger API (Plan 5) ---
# Internal HTTP endpoint exposed by the comfyui-trigger-api systemd unit.
# Web app POSTs here to enqueue Celery tasks on demand. Localhost-only.
SCANNER_TRIGGER_API_URL=http://127.0.0.1:8081
